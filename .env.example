# MyXodim sanity suite — environment config.
# Copy to .env and adjust. Defaults target the STAGING environment.

# --- Base URLs (staging) ---
CLIENT_URL=https://myxodim-stage.greatmall.uz
ADMIN_URL=https://myxodim-admin-stage.greatmall.uz
MOCK1C_URL=https://mock1c-stage.greatmall.uz
API_URL=https://myxodim-api-stage.greatmall.uz

# --- Client (end-user) login ---
# Staging accepts ANY 6-digit OTP; the phone must be a registered user.
CLIENT_PHONE=+998994002396
TEST_OTP=123456
# A known EMPLOYEE-role user (restricted access) for the RBAC case (28).
CLIENT_EMPLOYEE_PHONE=+998994002396

# --- Admin (platform) login ---
ADMIN_PHONE=+998991234567
ADMIN_PASSWORD=admin123

# --- UI locale used for assertions (staging default is RU) ---
LOCALE=ru

# --- Happy-path data ---
# Template name available on staging used for document-create-to-draft.
SANITY_TEMPLATE_NAME=Заявление на отпуск

# --- Allure TestOps (results upload) ---
# Fill these from your TestOps instance, then run_sanity.sh uploads automatically.
ALLURE_ENDPOINT=
ALLURE_TOKEN=
ALLURE_PROJECT_ID=
ALLURE_LAUNCH_NAME=MyXodim sanity (staging)
